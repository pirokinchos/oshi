---
type Props = { title?: string }
const { title = "Oshi" } = Astro.props
import "../styles/main.scss"
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}assets/fonts/fonts.css`} />



    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
  </head>
  <body>
    <slot />
  </body>
</html>
